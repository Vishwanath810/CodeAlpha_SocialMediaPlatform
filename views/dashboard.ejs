<!DOCTYPE html>
<html>
<head>

    <title>Dashboard</title>

    <link rel="stylesheet" href="/css/style.css">

</head>

<body>

    <!-- Navbar -->

    <div class="navbar">

        <h2>SocialConnect</h2>

        <a href="/logout">Logout</a>

    </div>


    <!-- Main Layout -->

    <div class="main">

        <!-- Sidebar -->

        <div class="sidebar">

            <h3>Welcome 👋</h3>

            <p>
                Connect with people and share your thoughts.
            </p>

        </div>


        <!-- Feed -->

        <div class="feed">

            <!-- Create Post -->

            <div class="create-post">

                <h3>Create Post</h3>

                <form action="/posts/create" method="POST">

                    <textarea
                        name="content"
                        placeholder="What's on your mind?"
                        required
                    ></textarea>

                    <br><br>

                    <button type="submit">
                        Post
                    </button>

                </form>

            </div>


            <!-- All Posts -->

            <% posts.forEach(post => { %>

                <div class="post-card">

                    <!-- Post Header -->

                    <div class="post-header">

                        <div class="avatar">

                            <%= post.user.username.charAt(0).toUpperCase() %>

                        </div>

                        <div>

                            <h3>

                                <a href="/profile/<%= post.user._id %>">

                                    <%= post.user.username %>

                                </a>

                            </h3>

                            <!-- Timestamp -->

                            <p style="color:gray; font-size:13px; margin-top:5px;">

                                <%= new Date(post.createdAt).toLocaleString() %>

                            </p>

                        </div>

                    </div>


                    <!-- Post Content -->

                    <div class="post-content">

                        <p>
                            <%= post.content %>
                        </p>

                    </div>


                    <!-- Like Button -->

                    <form
                        action="/posts/like/<%= post._id %>"
                        method="POST"
                    >

                        <button type="submit">

                            ❤️ Like (<%= post.likes.length %>)

                        </button>

                    </form>


                    <!-- Delete Post -->

                    <form
                        action="/posts/delete/<%= post._id %>"
                        method="POST"
                    >

                        <button type="submit">

                            🗑 Delete Post

                        </button>

                    </form>


                    <hr>


                    <!-- Comments -->

                    <h4>Comments</h4>

                    <% post.comments.forEach(comment => { %>

                        <div class="comment-box">

                            <strong>
                                <%= comment.user.username %>
                            </strong>

                            :

                            <%= comment.text %>

                            <br><br>

                            <!-- Delete Comment -->

                            <form
                                action="/comments/delete/<%= comment._id %>"
                                method="POST"
                                style="display:inline;"
                            >

                                <button type="submit">

                                    Delete Comment

                                </button>

                            </form>

                        </div>

                    <% }) %>


                    <!-- Add Comment -->

                    <form
                        action="/comments/create/<%= post._id %>"
                        method="POST"
                    >

                        <input
                            type="text"
                            name="text"
                            placeholder="Add comment..."
                            required
                        >

                        <br><br>

                        <button type="submit">
                            Comment
                        </button>

                    </form>

                </div>

            <% }) %>

        </div>

    </div>

</body>
</html>